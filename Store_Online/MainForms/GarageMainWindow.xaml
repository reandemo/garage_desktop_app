<Window
    x:Class="Store_Online.MainForms.GarageMainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Store_Online.Core.Controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Garage Management System"
    Width="1400"
    Height="850"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <SolidColorBrush x:Key="AppBackground" Color="#F4F5F7"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#2F3944"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#B76E79"/>

        <Style x:Key="ModernMenuItem"
               TargetType="MenuItem">

            <Setter Property="Foreground"
                    Value="#2D3436"/>

            <Setter Property="FontSize"
                    Value="14"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Padding"
                    Value="15,8"/>

            <Setter Property="Margin"
                    Value="2"/>

        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <controls:GarageHeader
            Grid.Row="0"/>

        <!-- Top Menu -->
        <controls:GarageTopMenu
            x:Name="TopMenu"
            Grid.Row="1"/>

        <!-- Main Content -->
        <Frame
            x:Name="MainContent"
            Grid.Row="2"
            NavigationUIVisibility="Hidden"
            JournalOwnership="OwnsJournal"/>

        <!-- Status Bar -->
        <controls:GarageStatusBar
            Grid.Row="3"/>

    </Grid>

</Window>