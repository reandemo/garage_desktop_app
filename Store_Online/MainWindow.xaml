<Window
    x:Class="Store_Online.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Width="1400"
    Height="800"
    Icon="/Shared/Assets/Icons/garage.ico"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <SolidColorBrush x:Key="AppBackground" Color="#F4F5F7" />
        <SolidColorBrush x:Key="HeaderBrush" Color="#2D3436" />
        <SolidColorBrush x:Key="AccentBrush" Color="#B76E79" />

        <Style x:Key="ModernMenuItem" TargetType="MenuItem">

            <Setter Property="Foreground" Value="#2D3436" />

            <Setter Property="FontSize" Value="14" />

            <Setter Property="FontWeight" Value="SemiBold" />

            <Setter Property="Padding" Value="15,8" />

            <Setter Property="Margin" Value="2" />

        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">

        <Grid.RowDefinitions>

            <RowDefinition Height="55" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="*" />

        </Grid.RowDefinitions>

        <!--  HEADER  -->

        <Grid Grid.Row="0" Background="{StaticResource HeaderBrush}">

            <Grid.ColumnDefinitions>

                <ColumnDefinition />

                <ColumnDefinition Width="320" />

            </Grid.ColumnDefinitions>

            <StackPanel
                Margin="20,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <materialDesign:PackIcon
                    Width="30"
                    Height="30"
                    Foreground="{StaticResource AccentBrush}"
                    Kind="Car" />

                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Garage Management System" />

            </StackPanel>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">

                <Button
                    Name="btnAdmin"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="btnAdmin_Click"
                    Cursor="Hand">

                    <StackPanel Orientation="Horizontal">

                        <materialDesign:PackIcon
                            Width="28"
                            Height="28"
                            Foreground="{StaticResource AccentBrush}"
                            Kind="AccountCircle" />

                        <TextBlock
                            Margin="8,0"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Text="Administrator" />

                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            Foreground="White"
                            Kind="ChevronDown" />

                    </StackPanel>

                    <Button.ContextMenu>
                        <ContextMenu>

                            <MenuItem Header="My Profile">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Account" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Change Password">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="LockReset" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator />

                            <MenuItem Header="Settings">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Cog" />
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator />

                            <MenuItem Header="Logout">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Foreground="#EF4444" Kind="Logout" />
                                </MenuItem.Icon>
                            </MenuItem>

                        </ContextMenu>
                    </Button.ContextMenu>

                </Button>

            </StackPanel>

        </Grid>

        <!--  MENU  -->

        <Border
            Grid.Row="1"
            Background="#FAFAFA"
            BorderBrush="#E5E7EB"
            BorderThickness="0,0,0,1">

            <Menu Background="Transparent" BorderThickness="0">

                <!--  FILE  -->

                <MenuItem Style="{StaticResource ModernMenuItem}">

                    <MenuItem.Header>

                        <StackPanel Orientation="Horizontal">

                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Foreground="{StaticResource AccentBrush}"
                                Kind="Folder" />

                            <TextBlock Margin="6,0,0,0" Text="File" />

                        </StackPanel>

                    </MenuItem.Header>

                    <MenuItem Header="Register Customer" />
                    <MenuItem Header="Plate Number" />
                    <Separator />
                    <MenuItem Header="Exit" />

                </MenuItem>

                <!--  POS  -->

                <MenuItem Style="{StaticResource ModernMenuItem}">

                    <MenuItem.Header>

                        <StackPanel Orientation="Horizontal">

                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Foreground="#3B82F6"
                                Kind="CashRegister" />

                            <TextBlock Margin="6,0,0,0" Text="POS" />

                        </StackPanel>

                    </MenuItem.Header>

                    <MenuItem Header="Garage POS" />

                </MenuItem>

                <!--  AUTHORIZE  -->

                <MenuItem Style="{StaticResource ModernMenuItem}">

                    <MenuItem.Header>

                        <StackPanel Orientation="Horizontal">

                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Foreground="#10B981"
                                Kind="ShieldCheck" />

                            <TextBlock Margin="6,0,0,0" Text="Authorize" />

                        </StackPanel>

                    </MenuItem.Header>

                    <MenuItem Header="Authorize POS" />
                    <MenuItem Header="Return POS" />

                </MenuItem>

                <!--  TOOLS  -->

                <MenuItem Style="{StaticResource ModernMenuItem}">

                    <MenuItem.Header>

                        <StackPanel Orientation="Horizontal">

                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Foreground="#F59E0B"
                                Kind="Toolbox" />

                            <TextBlock Margin="6,0,0,0" Text="Tools" />

                        </StackPanel>

                    </MenuItem.Header>

                    <MenuItem Header="Register Product" />
                    <MenuItem Header="Register Car Info" />

                </MenuItem>

                <!--  SETTING  -->

                <MenuItem Style="{StaticResource ModernMenuItem}">

                    <MenuItem.Header>

                        <StackPanel Orientation="Horizontal">

                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Foreground="#8B5CF6"
                                Kind="Cog" />

                            <TextBlock Margin="6,0,0,0" Text="Setting" />

                        </StackPanel>

                    </MenuItem.Header>

                    <MenuItem Header="Register User" />

                </MenuItem>

                <!--  ABOUT  -->

                <MenuItem Style="{StaticResource ModernMenuItem}">

                    <MenuItem.Header>

                        <StackPanel Orientation="Horizontal">

                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Foreground="#EF4444"
                                Kind="Information" />

                            <TextBlock Margin="6,0,0,0" Text="About" />

                        </StackPanel>

                    </MenuItem.Header>

                    <MenuItem Header="About System" />
                    <MenuItem Header="System Update" />

                </MenuItem>

            </Menu>

        </Border>

        <!--  CONTENT  -->

        <materialDesign:Card
            Grid.Row="2"
            Margin="15"
            Padding="10">

            <Frame x:Name="frame" NavigationUIVisibility="Hidden" />

        </materialDesign:Card>

    </Grid>

</Window>
