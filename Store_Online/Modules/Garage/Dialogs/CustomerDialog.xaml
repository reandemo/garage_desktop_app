<Window
    x:Class="Store_Online.Modules.Garage.Dialogs.CustomerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"

    Width="900"
    Height="620"

    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"

    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent">

    <Border
        Margin="12"
        Background="White"
        CornerRadius="18">

        <Grid>

            <Grid.RowDefinitions>

                <RowDefinition Height="60"/>

                <RowDefinition Height="*"/>

                <RowDefinition Height="65"/>

            </Grid.RowDefinitions>

            <!--================================================-->
            <!-- Header -->
            <!--================================================-->

            <Border
                Background="#1976D2"
                CornerRadius="18,18,0,0">

                <Grid Margin="20,0">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition/>

                        <ColumnDefinition Width="40"/>

                    </Grid.ColumnDefinitions>

                    <StackPanel
    VerticalAlignment="Center">

                        <!-- Title -->
                        <StackPanel Orientation="Horizontal">

                            <materialDesign:PackIcon
            Kind="AccountCircle"
            Width="28"
            Height="28"
            Margin="0,0,10,0"
            VerticalAlignment="Center"
            Foreground="White"/>

                            <TextBlock
            FontSize="22"
            FontWeight="SemiBold"
            Foreground="White"
            VerticalAlignment="Center"
            Text="Customer Information"/>

                        </StackPanel>

                        <!-- Description -->
                        <TextBlock
        Margin="38,4,0,0"
        FontSize="13"
        Foreground="White"
        Opacity="0.9"
        Text="Register customer before creating a booking."/>

                    </StackPanel>

                    <Button
                        Grid.Column="1"
                        Width="32"
                        Height="32"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Content="✕"
                        Click="BtnCancel_Click"/>

                </Grid>

            </Border>

            <!--================================================-->
            <!-- Body -->
            <!--================================================-->

            <Grid
                Grid.Row="1"
                Margin="35">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>

                    <ColumnDefinition Width="25"/>

                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>

                <!-- Code -->

                <StackPanel>

                    <TextBlock
                        Margin="0,0,0,4"
                        FontWeight="SemiBold"
                        Text="Customer Code *"/>

                    <TextBox
                        x:Name="txtCode"
                        Height="38"/>

                </StackPanel>

                <!-- Phone -->

                <StackPanel Grid.Column="2">

                    <TextBlock
                        Margin="0,0,0,4"
                        FontWeight="SemiBold"
                        Text="Phone Number *"/>

                    <TextBox
                        x:Name="txtPhone"
                        Height="38"/>

                </StackPanel>

                <!-- Name -->

                <StackPanel
                    Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Margin="0,18,0,0">

                    <TextBlock
                        Margin="0,0,0,4"
                        FontWeight="SemiBold"
                        Text="Customer Name *"/>

                    <TextBox
                        x:Name="txtName"
                        Height="38"/>

                </StackPanel>

                <!-- Telegram -->

                <StackPanel
                    Grid.Row="2"
                    Margin="0,18,0,0">

                    <TextBlock
                        Margin="0,0,0,4"
                        FontWeight="SemiBold"
                        Text="Telegram"/>

                    <TextBox Height="38"/>

                </StackPanel>

                <!-- Email -->

                <StackPanel
                    Grid.Row="2"
                    Grid.Column="2"
                    Margin="0,18,0,0">

                    <TextBlock
                        Margin="0,0,0,4"
                        FontWeight="SemiBold"
                        Text="Email"/>

                    <TextBox Height="38"/>

                </StackPanel>

                <!-- Address -->

                <StackPanel
                    Grid.Row="3"
                    Grid.ColumnSpan="3"
                    Margin="0,18,0,0">

                    <TextBlock
                        Margin="0,0,0,4"
                        FontWeight="SemiBold"
                        Text="Address"/>

                    <TextBox
                        Height="80"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"/>

                </StackPanel>

                <!-- Remark -->

                <StackPanel
                    Grid.Row="4"
                    Grid.ColumnSpan="3"
                    Margin="0,18,0,0">

                    <TextBlock
                        Margin="0,0,0,4"
                        FontWeight="SemiBold"
                        Text="Remark"/>

                    <TextBox
                        Height="70"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"/>

                </StackPanel>

            </Grid>

            <!--================================================-->
            <!-- Footer -->
            <!--================================================-->

            <Border
                Grid.Row="2"
                Background="#FAFAFA"
                BorderBrush="#E5E5E5"
                BorderThickness="0,1,0,0">

                <Grid Margin="25,10">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition/>

                        <ColumnDefinition Width="Auto"/>

                        <ColumnDefinition Width="12"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="Gray"
                        FontSize="12"
                        Text="* Required fields"/>

                    <Button
                        Grid.Column="1"
                        Width="150"
                        Height="42"
                        Background="#1976D2"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Content="💾 Save Customer"
                        Click="BtnSave_Click"/>

                    <Button
                        Grid.Column="3"
                        Width="110"
                        Height="42"
                        Content="Cancel"
                        Click="BtnCancel_Click"/>

                </Grid>

            </Border>

        </Grid>

    </Border>

</Window>