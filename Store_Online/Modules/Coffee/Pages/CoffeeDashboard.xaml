<Page
    x:Class="Store_Online.Modules.Coffee.Pages.CoffeeDashboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Store_Online.Shared.UI.Controls"
    Title="CoffeeDashboard"
    Background="{StaticResource WindowBrush}"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="30">

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto" />

                <RowDefinition Height="Auto" />

                <RowDefinition Height="Auto" />

            </Grid.RowDefinitions>

            <!--  =======================================================  -->
            <!--  HEADER  -->
            <!--  =======================================================  -->

            <StackPanel>

                <TextBlock Style="{StaticResource Heading1}" Text="☕ Coffee Dashboard" />

                <TextBlock
                    Margin="0,5,0,25"
                    Style="{StaticResource BodyText}"
                    Text="Example page using the Rean UI Theme" />

            </StackPanel>

            <!--  =======================================================  -->
            <!--  CARD  -->
            <!--  =======================================================  -->

            <Border Grid.Row="1" Style="{StaticResource CardBorder}">

                <StackPanel>

                    <TextBlock
                        Margin="0,0,0,20"
                        Style="{StaticResource Heading2}"
                        Text="Sample Form" />

                    <!--  Username  -->

                    <TextBlock Margin="0,0,0,5" Text="Coffee Name" />

                    <TextBox Width="300" Style="{StaticResource DefaultTextBox}" />

                    <!--  Search  -->

                    <TextBlock Margin="0,20,0,5" Text="Search" />

                    <TextBox Width="300" Style="{StaticResource SearchTextBox}" />

                    <!--  Combo  -->

                    <TextBlock Margin="0,20,0,5" Text="Category" />

                    <ComboBox Width="300" Style="{StaticResource DefaultComboBox}">

                        <ComboBoxItem Content="Coffee" />

                        <ComboBoxItem Content="Tea" />

                        <ComboBoxItem Content="Cake" />

                    </ComboBox>

                    <!--  Buttons  -->

                    <StackPanel Margin="0,30,0,0" Orientation="Horizontal">

                        <Button
                            Width="120"
                            Margin="0,0,10,0"
                            Style="{StaticResource PrimaryButton}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Margin="0,0,8,0"
                                    FontFamily="{StaticResource IconFont}"
                                    Text="&#xE74E;" />

                                <TextBlock Text="Save" />

                            </StackPanel>

                        </Button>

                        <Button
                            Width="120"
                            Margin="0,0,10,0"
                            Style="{StaticResource OutlineButton}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Margin="0,0,8,0"
                                    FontFamily="{StaticResource IconFont}"
                                    Text="&#xE70F;" />

                                <TextBlock Text="Edit" />

                            </StackPanel>

                        </Button>

                        <Button Width="120" Style="{StaticResource DangerButton}">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                    Margin="0,0,8,0"
                                    FontFamily="{StaticResource IconFont}"
                                    Text="&#xE74D;" />

                                <TextBlock Text="Delete" />

                            </StackPanel>

                        </Button>

                    </StackPanel>

                </StackPanel>

            </Border>

            <!--  =======================================================  -->
            <!--  SECOND CARD  -->
            <!--  =======================================================  -->

            <UniformGrid
                Grid.Row="2"
                Margin="0,25,0,0"
                Columns="3">

                <Border Style="{StaticResource SmallCard}">

                    <StackPanel>

                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource IconFont}"
                            FontSize="30"
                            Text="&#xECAF;" />

                        <TextBlock
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Style="{StaticResource Heading2}"
                            Text="Coffee" />

                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource BodyText}"
                            Text="125 Products" />

                    </StackPanel>

                </Border>

                <Border Style="{StaticResource SmallCard}">

                    <StackPanel>

                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource IconFont}"
                            FontSize="30"
                            Text="&#xE8EF;" />

                        <TextBlock
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Style="{StaticResource Heading2}"
                            Text="Orders" />

                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource BodyText}"
                            Text="54 Today" />

                    </StackPanel>

                </Border>

                <Border Style="{StaticResource SmallCard}">

                    <StackPanel>

                        <TextBlock
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource IconFont}"
                            FontSize="30"
                            Text="&#xE9D2;" />

                        <TextBlock
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Style="{StaticResource Heading2}"
                            Text="Revenue" />

                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource BodyText}"
                            Text="$2,350" />



                    </StackPanel>

                </Border>

            </UniformGrid>

        </Grid>

    </ScrollViewer>

</Page>
