<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Main Menu -->

    <Style x:Key="GarageMainMenuButtonStyle"
           TargetType="Button">

        <Setter Property="Background"
                Value="Transparent"/>

        <Setter Property="BorderBrush"
                Value="Transparent"/>

        <Setter Property="BorderThickness"
                Value="0"/>

        <Setter Property="Foreground"
                Value="#374151"/>

        <Setter Property="FontSize"
                Value="14"/>

        <Setter Property="FontWeight"
                Value="SemiBold"/>

        <Setter Property="Padding"
                Value="12,8"/>

        <Setter Property="HorizontalContentAlignment"
                Value="Left"/>

        <Setter Property="Cursor"
                Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border
                        Background="{TemplateBinding Background}"
                        CornerRadius="8">

                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Center"/>

                    </Border>

                </ControlTemplate>

            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <Trigger Property="IsMouseOver"
                     Value="True">

                <Setter Property="Background"
                        Value="#F3F4F6"/>

            </Trigger>

            <Trigger Property="IsPressed"
                     Value="True">

                <Setter Property="Background"
                        Value="#E5E7EB"/>

            </Trigger>

        </Style.Triggers>

    </Style>

    <!-- Selected Main Menu -->

    <Style x:Key="GarageMainMenuSelectedStyle"
           TargetType="Button"
           BasedOn="{StaticResource GarageMainMenuButtonStyle}">

        <Setter Property="Foreground"
                Value="#DC2626"/>

        <Setter Property="FontWeight"
                Value="Bold"/>

    </Style>

    <!-- Sub Menu -->

    <Style x:Key="GarageSubMenuButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource GarageMainMenuButtonStyle}">

        <Setter Property="FontSize"
                Value="13"/>

        <Setter Property="Padding"
                Value="28,6"/>

        <Setter Property="Foreground"
                Value="#6B7280"/>

    </Style>

    <!-- Selected Sub Menu -->

    <Style x:Key="GarageSubMenuSelectedStyle"
           TargetType="Button"
           BasedOn="{StaticResource GarageSubMenuButtonStyle}">

        <Setter Property="Foreground"
                Value="#DC2626"/>

        <Setter Property="FontWeight"
                Value="Bold"/>

    </Style>

</ResourceDictionary>