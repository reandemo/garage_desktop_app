<UserControl
    x:Class="Store_Online.Core.Controls.BusyOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid Background="#80000000">

        <Border
            Width="280"
            Height="160"
            CornerRadius="10"
            Background="White"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <ProgressBar
                    Width="180"
                    Height="18"
                    Margin="0,10"
                    IsIndeterminate="True"/>

                <TextBlock
                    Margin="0,20,0,0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Text="Please wait..."/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>