<UserControl x:Class="Store_Online.Core.Controls.Menus.GarageMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Store_Online.Core.Controls.Menus"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Menu>

            <MenuItem Header="_File">

                <MenuItem Header="Login"/>

                <MenuItem Header="Logout"/>

                <Separator/>

                <MenuItem Header="Exit"/>

            </MenuItem>

            <MenuItem Header="_Garage">

                <MenuItem Header="Customers"/>

                <MenuItem Header="Vehicles"/>

                <MenuItem Header="Vehicle Brands"/>

            </MenuItem>

            <MenuItem Header="_Inventory">

                <MenuItem Header="Products"/>

                <MenuItem Header="Stock In"/>

                <MenuItem Header="Stock Out"/>

            </MenuItem>

        </Menu>
    </Grid>
</UserControl>
