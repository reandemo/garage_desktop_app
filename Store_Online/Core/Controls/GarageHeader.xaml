<UserControl
    x:Class="Store_Online.Core.Controls.GarageHeader"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Store_Online.Core.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Height="64"
    mc:Ignorable="d">

    <Border
        Background="#1F2937"
        BorderBrush="#374151"
        BorderThickness="0,0,0,1">

        <Grid Margin="20,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Logo  -->
            <Border
                Width="44"
                Height="44"
                VerticalAlignment="Center"
                Background="#2563EB"
                CornerRadius="10">

                <materialDesign:PackIcon
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Kind="Car" />

            </Border>

            <!--  Application  -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center">

                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Garage Management System" />

                <TextBlock
                    Margin="0,2,0,0"
                    FontSize="12"
                    Foreground="#9CA3AF"
                    Text="Store Online ERP" />

            </StackPanel>

            <!--  Language  -->
            <Border
                Grid.Column="3"
                Height="40"
                VerticalAlignment="Center"
                Background="#1F2937"
                CornerRadius="8">

                <Menu
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0">

                    <Menu.Resources>

                        <Style TargetType="Menu">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="White" />
                        </Style>

                        <Style TargetType="MenuItem">
                            <Setter Property="Foreground" Value="Black" />
                            <Setter Property="FontSize" Value="13" />
                        </Style>

                    </Menu.Resources>

                    <MenuItem
                        Padding="12,8"
                        VerticalContentAlignment="Center"
                        Foreground="White">

                        <MenuItem.Header>

                            <Grid VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Image
                                    x:Name="imgCurrentLanguage"
                                    Grid.Column="0"
                                    Width="20"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Stretch="Fill" />

                                <TextBlock
                                    x:Name="txtCurrentLanguage"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="English" />

                            </Grid>

                        </MenuItem.Header>

                        <MenuItem Click="English_Click" Header="🇺🇸 English" />

                        <MenuItem Click="Khmer_Click" Header="🇰🇭 ខ្មែរ" />

                        <MenuItem Click="Chinese_Click" Header="🇨🇳 中文" />

                    </MenuItem>
                </Menu>

            </Border>

            <!--  Notification  -->
            <Button
                Grid.Column="5"
                Width="40"
                Height="40"
                Padding="0"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                ToolTip="Notifications">

                <Border Background="Transparent" CornerRadius="8">

                    <Grid>

                        <materialDesign:PackIcon
                            Width="20"
                            Height="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Kind="BellOutline" />

                        <Border
                            Height="18"
                            MinWidth="18"
                            Margin="0,-2,-2,0"
                            Padding="4,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="#EF4444"
                            BorderBrush="White"
                            BorderThickness="1"
                            CornerRadius="9">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="9"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="22" />

                        </Border>

                    </Grid>

                </Border>

                <Button.Style>

                    <Style TargetType="Button">

                        <Setter Property="Background" Value="Transparent" />

                        <Setter Property="Template">

                            <Setter.Value>

                                <ControlTemplate TargetType="Button">

                                    <Border
                                        x:Name="RootBorder"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">

                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />

                                    </Border>

                                    <ControlTemplate.Triggers>

                                        <Trigger Property="IsMouseOver" Value="True">

                                            <Setter TargetName="RootBorder" Property="Background" Value="#374151" />

                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">

                                            <Setter TargetName="RootBorder" Property="Background" Value="#4B5563" />

                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>

                            </Setter.Value>

                        </Setter>

                    </Style>

                </Button.Style>

            </Button>

            <!--  User Profile  -->
            <controls:UserProfileMenu Grid.Column="7" VerticalAlignment="Center" />

        </Grid>

    </Border>

</UserControl>