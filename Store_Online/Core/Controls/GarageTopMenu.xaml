<UserControl
    x:Class="Store_Online.Core.Controls.GarageTopMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        Background="White"
        BorderBrush="#D8D8D8"
        BorderThickness="0,0,0,1">
        <Menu
            x:Name="Menu"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderThickness="0"
            FontFamily="Segoe UI"
            FontSize="13">

            <Menu.Resources>

                <Style TargetType="{x:Type MenuItem}">
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Padding" Value="10,5" />
                </Style>

            </Menu.Resources>

            <!--  =============================  -->
            <!--  FILE  -->
            <!--  =============================  -->

            <MenuItem Header="_File">

                <MenuItem.Icon>
                    <materialDesign:PackIcon
                        Width="16"
                        Height="16"
                        Foreground="#E53935"
                        Kind="FolderOutline" />
                </MenuItem.Icon>

                <MenuItem
                    x:Name="DashboardMenu"
                    Click="Menu_Click"
                    Header="Dashboard"
                    Tag="Dashboard">

                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="ViewDashboard" />
                    </MenuItem.Icon>

                </MenuItem>

                <Separator />

                <MenuItem
                    Click="Menu_Click"
                    Header="Settings"
                    Tag="Settings">

                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="CogOutline" />
                    </MenuItem.Icon>

                </MenuItem>

                <Separator />

                <MenuItem Click="Exit_Click" Header="Exit">

                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="ExitToApp" />
                    </MenuItem.Icon>

                </MenuItem>

            </MenuItem>

            <!--  =============================  -->
            <!--  GARAGE  -->
            <!--  =============================  -->

            <MenuItem Header="_Garage">

                <MenuItem.Icon>
                    <materialDesign:PackIcon
                        Width="16"
                        Height="16"
                        Foreground="#1E88E5"
                        Kind="CarWrench" />
                </MenuItem.Icon>

                <MenuItem
                    Click="Menu_Click"
                    Header="Customers"
                    Tag="Customers">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="AccountGroup" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Click="Menu_Click"
                    Header="Vehicles"
                    Tag="Vehicles">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="Car" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    Click="Menu_Click"
                    Header="Vehicle Brands"
                    Tag="VehicleBrands">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="CarInfo" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Click="Menu_Click"
                    Header="Transmission Types"
                    Tag="TransmissionTypes">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="CogSync" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <!--  =============================  -->
            <!--  INVENTORY  -->
            <!--  =============================  -->

            <MenuItem Header="_Inventory">

                <MenuItem.Icon>
                    <materialDesign:PackIcon
                        Width="16"
                        Height="16"
                        Foreground="#43A047"
                        Kind="PackageVariant" />
                </MenuItem.Icon>

                <MenuItem
                    Click="Menu_Click"
                    Header="Products"
                    Tag="Products">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="PackageVariantClosed" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Click="Menu_Click"
                    Header="Categories"
                    Tag="ProductCategories">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="Shape" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Click="Menu_Click"
                    Header="Suppliers"
                    Tag="Suppliers">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="TruckDelivery" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <!--  =============================  -->
            <!--  REPORTS  -->
            <!--  =============================  -->

            <MenuItem Header="_Reports">

                <MenuItem.Icon>
                    <materialDesign:PackIcon
                        Width="16"
                        Height="16"
                        Foreground="#FB8C00"
                        Kind="ChartBar" />
                </MenuItem.Icon>

                <MenuItem
                    Click="Menu_Click"
                    Header="Dashboard Report"
                    Tag="DashboardReport">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="ChartTimelineVariant" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <!--  =============================  -->
            <!--  ADMIN  -->
            <!--  =============================  -->

            <MenuItem Header="_Admin">

                <MenuItem.Icon>
                    <materialDesign:PackIcon
                        Width="16"
                        Height="16"
                        Foreground="#8E24AA"
                        Kind="ShieldAccount" />
                </MenuItem.Icon>

                <MenuItem
                    Click="Menu_Click"
                    Header="Users"
                    Tag="Users">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="AccountMultiple" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Click="Menu_Click"
                    Header="Company"
                    Tag="Company">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="Domain" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

            <!--  =============================  -->
            <!--  HELP  -->
            <!--  =============================  -->

            <MenuItem Header="_Help">

                <MenuItem.Icon>
                    <materialDesign:PackIcon
                        Width="16"
                        Height="16"
                        Foreground="#EF5350"
                        Kind="HelpCircleOutline" />
                </MenuItem.Icon>

                <MenuItem
                    Click="Menu_Click"
                    Header="About"
                    Tag="About">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon
                            Width="15"
                            Height="15"
                            Kind="InformationOutline" />
                    </MenuItem.Icon>
                </MenuItem>

            </MenuItem>

        </Menu>

    </Border>

</UserControl>