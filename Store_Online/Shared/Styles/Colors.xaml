<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush
        x:Key="PrimaryBrush"
        Color="#2563EB"/>

    <SolidColorBrush
        x:Key="SecondaryBrush"
        Color="#64748B"/>

    <SolidColorBrush
        x:Key="BackgroundBrush"
        Color="#F8FAFC"/>

    <SolidColorBrush
        x:Key="CardBrush"
        Color="#FFFFFF"/>

    <SolidColorBrush
        x:Key="HintBrush"
        Color="#94A3B8"/>

</ResourceDictionary>
