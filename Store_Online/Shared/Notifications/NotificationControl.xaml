<UserControl
    x:Class="Store_Online.Shared.Notifications.NotificationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Store_Online.Shared.Notifications"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Visibility="Collapsed">
    <Border
        x:Name="MainBorder"
        Width="333"
        Height="42"
        Margin="0,5,0,5"
        Padding="10,0"
        Background="#FFF7ED"
        BorderBrush="#FDBA74"
        BorderThickness="1"
        CornerRadius="10">

        <Border.Effect>
            <DropShadowEffect
                BlurRadius="8"
                Opacity="0.10"
                ShadowDepth="0" />
        </Border.Effect>

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="22" />
            </Grid.ColumnDefinitions>

            <!--  Icon  -->

            <TextBlock
                x:Name="txtIcon"
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="15"
                FontWeight="Bold"
                Foreground="#EA580C"
                Text="⚠" />

            <!--  Message  -->

            <TextBlock
                x:Name="txtMessage"
                Grid.Column="1"
                Margin="3,0,0,0"
                VerticalAlignment="Center"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="#444"
                Text="Please enter your email." />

            <!--  Close  -->

            <Button
                Grid.Column="2"
                Width="18"
                Height="18"
                Background="Transparent"
                BorderThickness="0"
                Click="btnClose_Click"
                Content="✕"
                Cursor="Hand"
                FontSize="10"
                FontWeight="Bold"
                Foreground="#666" />

        </Grid>

    </Border>

</UserControl>
