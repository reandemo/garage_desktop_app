<Window
    x:Class="Store_Online.Shared.Notifications.NotificationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="420"
    Height="110"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStyle="None">

    <Border
        x:Name="MainBorder"
        Padding="15"
        Background="#1E293B"
        CornerRadius="18">

        <Border.Effect>
            <DropShadowEffect
                BlurRadius="25"
                Opacity="0.35"
                ShadowDepth="0"
                Color="Black" />
        </Border.Effect>

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="65" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>

            <!--  Icon  -->
            <Border
                x:Name="IconBorder"
                Width="50"
                Height="50"
                VerticalAlignment="Center"
                Background="#16A34A"
                CornerRadius="25">

                <TextBlock
                    x:Name="txtIcon"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontFamily="Segoe UI Symbol"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="✓" />

            </Border>

            <!--  Content  -->
            <StackPanel
                Grid.Column="1"
                Margin="12,0,0,0"
                VerticalAlignment="Center">

                <TextBlock
                    x:Name="txtTitle"
                    FontSize="17"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Success" />

                <TextBlock
                    x:Name="txtMessage"
                    Margin="0,5,0,0"
                    FontSize="13"
                    Foreground="#CBD5E1"
                    Text="Data saved successfully."
                    TextWrapping="Wrap" />

            </StackPanel>

            <!--  Close Button  -->
            <Button
                x:Name="btnClose"
                Grid.Column="2"
                Width="20"
                Height="20"
                Margin="0,2,2,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="Transparent"
                BorderThickness="0"
                Click="btnClose_Click"
                Content="✕"
                Cursor="Hand"
                FontSize="11"
                FontWeight="Bold"
                Foreground="#CBD5E1">

                <Button.Style>
                    <Style TargetType="Button">

                        <Setter Property="Opacity" Value="0.6" />

                        <Style.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter Property="Opacity" Value="1" />

                                <Setter Property="Foreground" Value="White" />

                            </Trigger>

                        </Style.Triggers>

                    </Style>
                </Button.Style>

            </Button>

        </Grid>

    </Border>

</Window>
