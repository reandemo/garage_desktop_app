<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <!--  Primary  -->

    <Color x:Key="PrimaryColor">#2F80ED</Color>

    <Color x:Key="PrimaryDark">#2166C2</Color>

    <Color x:Key="PrimaryLight">#5EA4F5</Color>

    <!--  Accent  -->

    <Color x:Key="SuccessColor">#27AE60</Color>

    <Color x:Key="WarningColor">#F2C94C</Color>

    <Color x:Key="DangerColor">#EB5757</Color>

    <!--  Background  -->

    <Color x:Key="WindowBackground">#F6F8FB</Color>

    <Color x:Key="CardBackground">White</Color>

    <!--  Text  -->

    <Color x:Key="TextPrimary">#1E293B</Color>

    <Color x:Key="TextSecondary">#64748B</Color>

    <Color x:Key="TextHint">#94A3B8</Color>

    <!--  Border  -->

    <Color x:Key="BorderColor">#E2E8F0</Color>

</ResourceDictionary>
