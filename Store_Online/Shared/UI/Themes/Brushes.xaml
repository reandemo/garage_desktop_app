<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!-- Primary -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="PrimaryBrush"
                     Color="{StaticResource PrimaryColor}" />

    <SolidColorBrush x:Key="PrimaryDarkBrush"
                     Color="{StaticResource PrimaryDark}" />

    <SolidColorBrush x:Key="PrimaryLightBrush"
                     Color="{StaticResource PrimaryLight}" />

    <!-- ===================================================== -->
    <!-- Status -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="SuccessBrush"
                     Color="{StaticResource SuccessColor}" />

    <SolidColorBrush x:Key="WarningBrush"
                     Color="{StaticResource WarningColor}" />

    <SolidColorBrush x:Key="DangerBrush"
                     Color="{StaticResource DangerColor}" />

    <!-- ===================================================== -->
    <!-- Background -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="WindowBrush"
                     Color="{StaticResource WindowBackground}" />

    <SolidColorBrush x:Key="CardBrush"
                     Color="{StaticResource CardBackground}" />

    <!-- ===================================================== -->
    <!-- Text -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="TextBrush"
                     Color="{StaticResource TextPrimary}" />

    <SolidColorBrush x:Key="TextPrimaryBrush"
                     Color="{StaticResource TextPrimary}" />

    <SolidColorBrush x:Key="TextSecondaryBrush"
                     Color="{StaticResource TextSecondary}" />

    <SolidColorBrush x:Key="HintBrush"
                     Color="{StaticResource TextHint}" />

    <!-- ===================================================== -->
    <!-- Border -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="BorderBrush"
                     Color="{StaticResource BorderColor}" />

    <!-- ===================================================== -->
    <!-- Extra Brushes (Recommended) -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="WhiteBrush"
                     Color="White" />

    <SolidColorBrush x:Key="BlackBrush"
                     Color="Black" />

    <SolidColorBrush x:Key="TransparentBrush"
                     Color="Transparent" />

</ResourceDictionary>
