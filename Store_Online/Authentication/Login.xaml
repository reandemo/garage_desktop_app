<Window
    x:Class="Store_Online.Authentication.Login"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Store_Online.Shared.Notifications"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="500"
    Height="600"
    AllowsTransparency="True"
    Background="{x:Null}"
    FontFamily="{DynamicResource AppFont}"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    ResizeMode="NoResize"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Grid>

        <!--  Login Card  -->

        <materialDesign:Card
            Width="400"
            Padding="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            materialDesign:ElevationAssist.Elevation="Dp4"
            UniformCornerRadius="15">

            <materialDesign:DialogHost x:Name="DialogHost" CloseOnClickAway="True">

                <StackPanel Margin="10">

                    <!--  Popup Menu  -->

                    <materialDesign:PopupBox
                        Margin="0,5,10,0"
                        HorizontalAlignment="Right"
                        PlacementMode="BottomAndAlignRightEdges"
                        StaysOpen="False">

                        <materialDesign:PopupBox.ToggleContent>
                            <materialDesign:PackIcon
                                Width="28"
                                Height="28"
                                Cursor="Hand"
                                Foreground="#2196F3"
                                Kind="DotsVertical" />
                        </materialDesign:PopupBox.ToggleContent>

                        <Border
                            Padding="5"
                            Background="White"
                            CornerRadius="10">

                            <StackPanel Width="180">

                                <Button
                                    x:Name="Btn_SetupStore"
                                    HorizontalContentAlignment="Left"
                                    Click="Btn_setupstore_Click">

                                    <StackPanel Orientation="Horizontal">

                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Margin="0,0,10,0"
                                            Kind="HelpCircleOutline" />

                                        <TextBlock Text="Create Store ?" />

                                    </StackPanel>

                                </Button>

                                <Button
                                    x:Name="Btn_Exit"
                                    HorizontalContentAlignment="Left"
                                    Click="Btn_Exit_Click">

                                    <StackPanel Orientation="Horizontal">

                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Margin="0,0,10,0"
                                            Kind="ExitToApp" />

                                        <TextBlock Text="Exit" />

                                    </StackPanel>

                                </Button>

                            </StackPanel>

                        </Border>

                    </materialDesign:PopupBox>

                    <!--  Logo  -->

                    <Image
                        Width="100"
                        Height="100"
                        HorizontalAlignment="Center"
                        Source="/Shared/Assets/Images/money.png"
                        Stretch="Uniform" />

                    <!--  Title  -->

                    <TextBlock
                        Margin="0,10,0,5"
                        HorizontalAlignment="Center"
                        FontFamily="{DynamicResource HandFont}"
                        FontSize="28"
                        FontWeight="Bold"
                        Text="{Binding [APP_NAME], Source={StaticResource Lang}}" />

                    <TextBlock
                        Margin="0,0,30,0"
                        HorizontalAlignment="Right"
                        FontFamily="{DynamicResource HandFont}"
                        FontSize="17"
                        Foreground="#888888"
                        Text="Powered by REAN-PRO" />


                    <controls:NotificationControl x:Name="Notifier" Width="333" />

                    <!--  Username  -->

                    <TextBox
                        x:Name="txtUserlogin"
                        Width="333"
                        Margin="0,15,0,0"
                        materialDesign:HintAssist.Foreground="{StaticResource HintBrush}"
                        materialDesign:HintAssist.Hint="{Binding [LBL_USERNAME], Source={StaticResource Lang}}"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="Account"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="2"
                        FontFamily="{DynamicResource HandFont}"
                        FontSize="18"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                    <!--  Password  -->

                    <PasswordBox
                        x:Name="txtPassword"
                        Width="333"
                        Margin="0,15,0,0"
                        materialDesign:HintAssist.Foreground="{StaticResource HintBrush}"
                        materialDesign:HintAssist.Hint="{Binding [LBL_PASSWORD], Source={StaticResource Lang}}"
                        materialDesign:TextFieldAssist.HasLeadingIcon="True"
                        materialDesign:TextFieldAssist.LeadingIcon="Lock"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="2"
                        FontFamily="{DynamicResource HandFont}"
                        FontSize="18"
                        KeyDown="txtPassword_KeyDown"
                        Style="{StaticResource MaterialDesignOutlinedPasswordBox}" />

                    <!--  Login Button  -->

                    <Button
                        x:Name="btnLogin"
                        Width="333"
                        Height="55"
                        Margin="0,20,0,0"
                        materialDesign:ButtonAssist.CornerRadius="12"
                        materialDesign:ElevationAssist.Elevation="Dp8"
                        Background="#2563EB"
                        Click="Btn_login_Click"
                        Content="{Binding [BTN_LOGIN], Source={StaticResource Lang}}"
                        FontFamily="{DynamicResource HandFont}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="White" />

                </StackPanel>


            </materialDesign:DialogHost>

        </materialDesign:Card>


    </Grid>

</Window>
