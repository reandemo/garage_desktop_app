<Page
    x:Class="Store_Online.Views.UsersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Background="#F5F7FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Create User Card  -->
        <materialDesign:Card
            Grid.Row="0"
            Margin="0,0,0,15"
            Padding="20">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,20"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Text="Create User" />

                <!--  User Login  -->
                <TextBox
                    x:Name="txtUserLogin"
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="5"
                    materialDesign:HintAssist.Hint="User Login" />

                <!--  Password  -->
                <PasswordBox
                    x:Name="txtPassword"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="5" />

                <!--  Branch  -->
                <ComboBox
                    x:Name="cboBranch"
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="5"
                    materialDesign:HintAssist.Hint="Select Branch"
                    DisplayMemberPath="branch_name"
                    SelectedValuePath="id" />

                <!--  Profile  -->
                <ComboBox
                    x:Name="cboProfile"
                    Grid.Row="2"
                    Grid.Column="1"
                    Margin="5"
                    materialDesign:HintAssist.Hint="Select Profile"
                    DisplayMemberPath="profile_name"
                    SelectedValuePath="id" />

                <!--  Buttons  -->
                <StackPanel
                    Grid.Row="3"
                    Grid.ColumnSpan="2"
                    Margin="0,15,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

                    <Button
                        x:Name="btnSave"
                        Width="120"
                        Height="40"
                        Margin="5"
                        Click="btnSave_Click"
                        Content="Save User"
                        Style="{StaticResource MaterialDesignRaisedButton}" />

                    <Button
                        x:Name="btnClear"
                        Width="120"
                        Height="40"
                        Margin="5"
                        Content="Clear"
                        Style="{StaticResource MaterialDesignOutlinedButton}" />

                </StackPanel>

            </Grid>

        </materialDesign:Card>

        <!--  User List  -->
        <materialDesign:Card Grid.Row="1">

            <DockPanel Margin="10">

                <TextBox
                    x:Name="txtSearch"
                    Margin="0,0,0,10"
                    materialDesign:HintAssist.Hint="Search User"
                    DockPanel.Dock="Top" />

                <DataGrid
                    x:Name="dgUsers"
                    AutoGenerateColumns="False"
                    IsReadOnly="True">

                    <DataGrid.Columns>

                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding id}"
                            Header="ID" />

                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding username}"
                            Header="User Login" />

                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding branch_name}"
                            Header="Branch" />

                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding profile_name}"
                            Header="Profile" />

                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding status}"
                            Header="Status" />

                    </DataGrid.Columns>

                </DataGrid>

            </DockPanel>

        </materialDesign:Card>

    </Grid>

</Page>
