<Page
    x:Class="Store_Online.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Margin="20">

            <!--  Header  -->

            <Grid Margin="0,0,0,20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <StackPanel>

                    <TextBlock
                        FontSize="34"
                        FontWeight="Bold"
                        Text="Dashboard" />

                    <TextBlock
                        Margin="0,5,0,0"
                        FontSize="14"
                        Foreground="Gray"
                        Text="Garage Management Overview" />

                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">

                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="21 Jun 2026" />

                    <TextBlock Foreground="Gray" Text="Saturday" />

                </StackPanel>

            </Grid>

            <!--  Statistics  -->

            <UniformGrid Margin="0,0,0,20" Columns="4">

                <!--  Customer  -->

                <materialDesign:Card Margin="8">

                    <StackPanel Margin="15">

                        <materialDesign:PackIcon
                            Width="40"
                            Height="40"
                            Foreground="#3B82F6"
                            Kind="AccountGroup" />

                        <TextBlock Margin="0,10,0,0" Text="Customers" />

                        <TextBlock
                            FontSize="30"
                            FontWeight="Bold"
                            Text="1,250" />

                        <TextBlock Foreground="Green" Text="+15 Today" />

                    </StackPanel>

                </materialDesign:Card>

                <!--  Vehicle  -->

                <materialDesign:Card Margin="8">

                    <StackPanel Margin="15">

                        <materialDesign:PackIcon
                            Width="40"
                            Height="40"
                            Foreground="#10B981"
                            Kind="Car" />

                        <TextBlock Margin="0,10,0,0" Text="Vehicles Today" />

                        <TextBlock
                            FontSize="30"
                            FontWeight="Bold"
                            Text="580" />

                        <TextBlock Foreground="Green" Text="+28 Today" />

                    </StackPanel>

                </materialDesign:Card>

                <!--  Revenue  -->

                <materialDesign:Card Margin="8">

                    <StackPanel Margin="15">

                        <materialDesign:PackIcon
                            Width="40"
                            Height="40"
                            Foreground="#F59E0B"
                            Kind="Cash" />

                        <TextBlock Margin="0,10,0,0" Text="Revenue Today" />

                        <TextBlock
                            FontSize="30"
                            FontWeight="Bold"
                            Text="$12,500" />

                        <TextBlock Foreground="Green" Text="+8%" />

                    </StackPanel>

                </materialDesign:Card>

                <!--  Parking  -->

                <materialDesign:Card Margin="8">

                    <StackPanel Margin="15">

                        <materialDesign:PackIcon
                            Width="40"
                            Height="40"
                            Foreground="#8B5CF6"
                            Kind="Parking" />

                        <TextBlock Margin="0,10,0,0" Text="Parking Slots" />

                        <TextBlock
                            FontSize="30"
                            FontWeight="Bold"
                            Text="145" />

                        <TextBlock Foreground="Gray" Text="Available" />

                    </StackPanel>

                </materialDesign:Card>

            </UniformGrid>

            <!--  Quick Actions  -->

            <materialDesign:Card Margin="0,0,0,20">

                <StackPanel Margin="20">

                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Quick Actions" />

                    <WrapPanel Margin="0,15,0,0">

                        <Button
                            Width="170"
                            Height="45"
                            Margin="5"
                            Background="#3B82F6"
                            Content="+ Customer"
                            Foreground="White" />

                        <Button
                            Width="170"
                            Height="45"
                            Margin="5"
                            Background="#10B981"
                            Content="+ Vehicle"
                            Foreground="White" />

                        <Button
                            Width="170"
                            Height="45"
                            Margin="5"
                            Background="#F59E0B"
                            Content="POS"
                            Foreground="White" />

                        <Button
                            Width="170"
                            Height="45"
                            Margin="5"
                            Background="#8B5CF6"
                            Content="Report"
                            Foreground="White" />

                    </WrapPanel>

                </StackPanel>

            </materialDesign:Card>

            <!--  Recent Activity  -->

            <materialDesign:Card>

                <StackPanel Margin="20">

                    <TextBlock
                        Margin="0,0,0,15"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Recent Activity" />

                    <DataGrid Height="220" AutoGenerateColumns="False">

                        <DataGrid.Columns>

                            <DataGridTextColumn Binding="{Binding PlateNo}" Header="Plate No" />

                            <DataGridTextColumn Binding="{Binding Customer}" Header="Customer" />

                            <DataGridTextColumn Binding="{Binding CheckIn}" Header="Check In" />

                            <DataGridTextColumn Binding="{Binding Status}" Header="Status" />

                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>

            </materialDesign:Card>

        </StackPanel>

    </ScrollViewer>

</Page>
